setopt correct  		#To fix mistakes
setopt extendedglob 		#Allows regular expressions with *
setopt nocaseglob		#Case-Sensitive globbing
setopt rcexpandparam		#Array expansion with parameters
setopt nocheckjobs		#Nowarning when exiting
setopt numericglobsort  	#Numerical sorting to files
